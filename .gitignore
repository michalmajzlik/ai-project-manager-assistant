# Python
__pycache__/
*.py[cod]
*$py.class

# Environments and local secrets
.env
.env.*
!.env.example
*.secret
.venv/
venv/
ENV/

# Build/distribution
build/
dist/
*.egg-info/

# Logs and caches
*.log
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/
.ipynb_checkpoints/

# Meeting working data (local only)
Meetings/VTT/*
!Meetings/VTT/.gitkeep
Meetings/summaries/*
!Meetings/summaries/.gitkeep
Meetings/processed/*
!Meetings/processed/.gitkeep
Meetings/failed/*
!Meetings/failed/.gitkeep
Meetings/run_reports/*
!Meetings/run_reports/.gitkeep
Meetings/incoming_test/
Meetings/processed_test/
Meetings/VTT_test/
Meetings/processor.log

# Local/generated outputs
outputs/*
!outputs/.gitkeep
!outputs/README.md
!outputs/examples/
!outputs/examples/**

# Optional local project config if someone stores it in the repo by mistake
pm_reports/*.local.json
pm_reports/project_report_config.json
pm_reports/configs/local/
pm_reports/config_templates/local/

